# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Models (optional — defaults shown)
VITE_MODEL_OPUS=claude-opus-4-7
VITE_MODEL_SONNET=claude-sonnet-4-6

# Support email shown in the contact form (fallback hint if send fails)
VITE_SUPPORT_EMAIL=TriForgeTraining@gmail.com

# Resend (for the in-app support form) — get an API key at https://resend.com/api-keys
RESEND_API_KEY=
SUPPORT_TO_EMAIL=TriForgeTraining@gmail.com
# Sender. Use onboarding@resend.dev until you verify a domain in Resend.
SUPPORT_FROM_EMAIL=TriForge Support <onboarding@resend.dev>

# Firebase config — create a project at https://console.firebase.google.com/
# Project Settings > Your apps > Web app > SDK setup and configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Strava integration — create an app at https://www.strava.com/settings/api
# Set "Authorization Callback Domain" to: localhost
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback
APP_URL=http://localhost:5173
